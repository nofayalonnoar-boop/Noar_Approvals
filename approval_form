     ========================================== -->
  <script>
    // Constants & Globals
    const SUPABASE_URL = 'https://rbckzxfgtitknlfkfnhv.supabase.co';
    const SUPABASE_KEY = 'sb_publishable_CtYnbiiIcNlZVq9rmQwofg_htbw8lA5';
    
    const DEFAULT_COMMITMENT = `התחייבות ומשמעת:\nכללי התנהגות- תדרכתי את בני/בתי כי חל איסור מוחלט על היפרדות מהקבוצה, כניסה למים ללא אישור המדריך/המציל, עישון או שתיית אלכוהול.\nהחזרה מהטיול- חריגה מנהלי הבטיחות או התנהגות שאינה הולמת תגרור הרחקה מהטיול וחזרה הביתה באחריות ההורים ועל חשבונם.\nפינוי רפואי- במקרה של פציעה או מחלה במהלך הטיול, הצוות רשאי לפנות את החניך/ה לטיפול רפואי בתיאום.`;

    let parentFormTemplateObj = null; 
    let temporarySignatureBase64 = null; 
    
    // Canvas variables
    let canvas, ctx;
    let isDrawing = false;
    let lastX = 0;
    let lastY = 0;

    // Decode Template Metadata from the commitment text payload
    function decodeTemplateMetadata(t) {
      if (!t) return t;
      const copy = { ...t };
      
      const text = t.commitment_text || '';
      const marker = "\n===METADATA===\n";
      const markerIdx = text.indexOf(marker);
      
      if (markerIdx !== -1) {
        copy.commitment_text = text.substring(0, markerIdx);
        try {
          const rawMeta = text.substring(markerIdx + marker.length);
          const parsed = JSON.parse(rawMeta);
          copy.include_grade_question = parsed.include_grade_question !== false;
          copy.grades_options = parsed.grades_options || ['ט', 'י', 'יא', 'יב'];
        } catch (e) {
          console.warn("Could not parse metadata from commitment tail:", e);
        }
      } else {
        copy.include_grade_question = true;
        copy.grades_options = ['ט', 'י', 'יא', 'יב'];
      }
      return copy;
    }

    function getInitialDummyTemplates() {
      return [
        {
          id: 'template-sample-1',
          title: 'הצהרת בריאות ואישור הורים להשתתפות בטיול שנתי',
          activity_name: 'טיול שנתי לגליל העליון - כיתות ט׳-יב׳',
          show_water_clause: true,
          commitment_text: DEFAULT_COMMITMENT,
          created_at: new Date().toISOString()
        },
        {
          id: 'template-sample-2',
          title: 'אישור הורים לפעילות שיא קהילתית',
          activity_name: 'ערב סיום ופסטיבל פתיחת שנת נוער',
          show_water_clause: false,
          commitment_text: DEFAULT_COMMITMENT,
          created_at: new Date().toISOString()
        }
      ];
    }

    // App Initialization on DOM Load
    window.addEventListener('DOMContentLoaded', async () => {
      const urlParams = new URLSearchParams(window.location.search);
      const parentFormId = urlParams.get('id');

      if (!parentFormId) {
        // ID is missing, show invalid page
        document.getElementById('view-invalid-link').classList.remove('hidden');
        return;
      }

      // Display the filling UI
      document.getElementById('view-parent-fill').classList.remove('hidden');

      // Load form details
      await loadParentFormTemplate(parentFormId);

      // Configure validation change listeners
      const form = document.getElementById('parent-approval-form');
      if (form) {
        form.addEventListener('input', updateParentFormButtonState);
        form.addEventListener('change', updateParentFormButtonState);
      }
      updateParentFormButtonState();

      // Pre-initialize Canvas
      initSignatureCanvasEngine();
    });

    // Populate Loaded template
    async function loadParentFormTemplate(formId) {
      let templ = null;

      if (window.supabase) {
        try {
          const client = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
          const { data, error } = await client.from('parent_approvals').select('*').eq('id', formId).single();
          if (data && !error) {
            templ = data;
          }
        } catch (e) {
          console.warn("Supabase fetch error:", e);
        }
      }

      if (!templ) {
        // Look in localStorage
        const localT = localStorage.getItem('local_parent_approvals');
        if (localT) {
          const parsed = JSON.parse(localT);
          templ = parsed.find(t => t.id === formId);
        }
      }

      if (!templ) {
        // Fallback to dummies
        const dummies = getInitialDummyTemplates();
        templ = dummies.find(d => d.id === formId) || dummies[0];
      }

      parentFormTemplateObj = decodeTemplateMetadata(templ);
      const activeTempl = parentFormTemplateObj;

      // Update fields
      document.getElementById('parent-preview-title').innerText = activeTempl.title;
      document.getElementById('parent-preview-activity-badge').innerText = `עבור הפעילות: ${activeTempl.activity_name}`;
      document.getElementById('parent-preview-commitment-text').innerText = activeTempl.commitment_text;

      // Dynamically load classes
      const gradeContainer = document.getElementById('parent-child-grade-container');
      const gradeSelect = document.getElementById('parent-child-grade');

      if (activeTempl.include_grade_question === false) {
        if (gradeContainer) gradeContainer.classList.add('hidden');
        if (gradeSelect) {
          gradeSelect.required = false;
          gradeSelect.value = '';
        }
      } else {
        if (gradeContainer) gradeContainer.classList.remove('hidden');
        if (gradeSelect) {
          gradeSelect.required = true;
          const selectHtml = [`<option value="" disabled selected>בחר כיתה...</option>`];
          const grades = activeTempl.grades_options || ['ט', 'י', 'יא', 'יב'];
          grades.forEach(g => {
            let label = g + "'";
            if (g === 'יא') label = 'י"א';
            if (g === 'יב') label = 'י"ב';
            selectHtml.push(`<option value="${g}">כיתה ${label}</option>`);
          });
          gradeSelect.innerHTML = selectHtml.join('');
        }
      }

      // Water clause
      const waterClauseBlock = document.getElementById('parent-water-clause-block');
      if (activeTempl.show_water_clause) {
        waterClauseBlock.classList.remove('hidden');
        document.querySelectorAll('input[name="water-clause"]').forEach(i => i.required = true);
      } else {
        waterClauseBlock.classList.add('hidden');
        document.querySelectorAll('input[name="water-clause"]').forEach(i => i.required = false);
      }
    }

    // Toggle health details textarea
    function toggleHealthClauseDetails(show) {
      const container = document.getElementById('health-details-container');
      const textarea = document.getElementById('health-details-textarea');
      if (show) {
        container.classList.remove('hidden');
        if (textarea) textarea.required = true;
      } else {
        container.classList.add('hidden');
        if (textarea) {
          textarea.required = false;
          textarea.value = '';
        }
      }
      updateParentFormButtonState();
    }

    // Submit declaration
    async function submitParentDeclaration(event) {
      event.preventDefault();

      if (!parentFormTemplateObj) {
        Swal.fire({ icon: 'error', title: 'שגיאה', text: 'שגיאה באפיון תבנית הפעילות.' });
        return;
      }

      const childName = document.getElementById('parent-child-name').value.trim();
      const childId = document.getElementById('parent-child-id').value.trim();
      const childGrade = document.getElementById('parent-child-grade').value;

      const parentName = document.getElementById('parent-parent-name').value.trim();
      const parentPhone = document.getElementById('parent-parent-phone').value.trim();
      const parentId = document.getElementById('parent-parent-id').value.trim();

      const healthClauseEl = document.querySelector('input[name="health-clause"]:checked');
      const waterClauseEl = document.querySelector('input[name="water-clause"]:checked');

      // Basic validates
      const isGradeNeeded = parentFormTemplateObj.include_grade_question !== false;
      if (!childName || !childId || (isGradeNeeded && !childGrade) || !parentName || !parentPhone || !parentId) {
        Swal.fire({ icon: 'warning', title: 'שדות חסרים', text: 'אנא מלאו את כל שדות החובה המסומנים בכוכבית (*).' });
        return;
      }

      if (childId.length !== 9 || isNaN(childId)) {
        Swal.fire({ icon: 'error', title: 'ת.ז חניך שגויה', text: 'תעודת הזהות של החניך חייבת להכיל בדיוק 9 ספרות.' });
        return;
      }
      if (parentId.length !== 9 || isNaN(parentId)) {
        Swal.fire({ icon: 'error', title: 'ת.ז הורה שגויה', text: 'תעודת הזהות של ההורה החותם חייבת להכיל בדיוק 9 ספרות.' });
        return;
      }
      if (parentPhone.length !== 10 || isNaN(parentPhone) || !parentPhone.startsWith('05')) {
        Swal.fire({ icon: 'error', title: 'מספר טלפון שגוי', text: 'מספר הטלפון של ההורה חייב להכיל בדיוק 10 ספרות, ללא מקפים ולהתחיל ב-05.' });
        return;
      }

      if (!temporarySignatureBase64) {
        Swal.fire({ icon: 'error', title: 'חתימה חסרה', text: 'אנא פתחו את משטח החתימה וחתמו לאישור סופי.' });
        return;
      }

      const healthOption = healthClauseEl ? healthClauseEl.value : 'none';
      const healthDetails = document.getElementById('health-details-textarea').value.trim();
      const waterOption = (parentFormTemplateObj.show_water_clause && waterClauseEl) ? waterClauseEl.value : null;

      const newSubmission = {
        id: 'sub-' + Math.random().toString(36).substr(2, 9),
        approval_id: parentFormTemplateObj.id,
        child_name: childName,
        child_national_id: childId,
        child_grade: childGrade,
        parent_name: parentName,
        parent_phone: parentPhone,
        parent_national_id: parentId,
        health_declaration_option: healthOption,
        health_declaration_details: healthOption === 'custom' ? healthDetails : null,
        water_declaration_option: waterOption,
        signature_svg: temporarySignatureBase64,
        created_at: new Date().toISOString()
      };

      Swal.showLoading();

      let savedCloudRecord = null;
      let success = false;

      if (window.supabase) {
        try {
          const client = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
          const cloudRecord = { ...newSubmission };
          delete cloudRecord.id;

          const { data, error } = await client.from('parent_submissions').insert(cloudRecord).select();
          if (error) throw error;
          if (data && data.length > 0) {
            savedCloudRecord = data[0];
            success = true;
          }
        } catch (cloudErr) {
          console.warn("Could not insert parent response in Supabase. Backing up locally...", cloudErr);
        }
      }

      if (!success) {
        // Save locally
        const savedSubmissions = localStorage.getItem('local_parent_submissions');
        const list = savedSubmissions ? JSON.parse(savedSubmissions) : [];
        list.push(newSubmission);
        localStorage.setItem('local_parent_submissions', JSON.stringify(list));
        savedCloudRecord = newSubmission;
      }

      Swal.close();

      // Show compiled result
      renderCompletedParentStatementHTML(savedCloudRecord);
    }

    function renderCompletedParentStatementHTML(subObj) {
      if (!subObj) return;

      // Populate statement elements
      document.getElementById('pdf-doc-title').innerText = parentFormTemplateObj.title;
      document.getElementById('pdf-doc-activity-badge').innerText = `עבור: ${parentFormTemplateObj.activity_name}`;
      document.getElementById('pdf-doc-id-ref').innerText = subObj.id ? subObj.id.replace('sub-', '').toUpperCase() : 'LOCAL-TEMP';

      document.getElementById('pdf-child-name').innerText = subObj.child_name;
      document.getElementById('pdf-child-id').innerText = subObj.child_national_id;

      const pdfGradeContainer = document.getElementById('pdf-child-grade-container');
      const pdfGradeVal = document.getElementById('pdf-child-grade');

      if (parentFormTemplateObj.include_grade_question === false) {
        if (pdfGradeContainer) pdfGradeContainer.classList.add('hidden');
      } else {
        if (pdfGradeContainer) pdfGradeContainer.classList.remove('hidden');
        if (pdfGradeVal) {
          let label = subObj.child_grade + "'";
          if (subObj.child_grade === 'יא') label = 'י"א';
          if (subObj.child_grade === 'יb' || subObj.child_grade === 'יב') label = 'י"ב';
          pdfGradeVal.innerText = `כיתה ${label}`;
        }
      }

      document.getElementById('pdf-parent-name').innerText = subObj.parent_name;
      document.getElementById('pdf-parent-phone').innerText = subObj.parent_phone;
      document.getElementById('pdf-parent-id').innerText = subObj.parent_national_id;

      // Declaration Options Results
      const healthRes = document.getElementById('pdf-health-clause-result');
      const healthDetailsBlock = document.getElementById('pdf-health-details-block');
      if (subObj.health_declaration_option === 'none') {
        healthRes.innerText = "✓ לא ידוע לי על מגבלה רפואית המונעת השתתפות מלאה.";
        healthDetailsBlock.classList.add('hidden');
      } else {
        healthRes.innerText = "✗ מצהיר כי לחניך יש מגבלה רפואית כרונית / רגישות / אלרגיה מסכנת חיים.";
        healthDetailsBlock.classList.remove('hidden');
        document.getElementById('pdf-health-details-value').innerText = subObj.health_declaration_details || 'לא צוינה';
      }

      // Water details
      const waterDocBlock = document.getElementById('pdf-water-clause-block');
      if (subObj.water_declaration_option) {
        waterDocBlock.classList.remove('hidden');
        const waterRes = document.getElementById('pdf-water-clause-result');
        if (subObj.water_declaration_option === 'can_swim') {
          waterRes.innerText = "✓ מאשר/ת כי בני/בתי יודע/ת לשחות ומאשר/ת כניסה למים.";
        } else {
          waterRes.innerText = "✗ בני/בתי אינו/ה יודע/ת לשחות. רשאי/ת להיכנס עד גובה מותניים תחת השגחה.";
        }
      } else {
        waterDocBlock.classList.add('hidden');
      }

      // Commitment
      document.getElementById('pdf-commitment-terms-block').innerText = parentFormTemplateObj.commitment_text;

      // Signing Date and Signature preview block
      const dateOption = { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' };
      document.getElementById('pdf-doc-signed-date').innerText = new Date(subObj.created_at).toLocaleDateString('he-IL', dateOption);
      document.getElementById('pdf-signature-img').src = subObj.signature_svg;

      // Toggle views
      document.getElementById('view-parent-fill').classList.add('hidden');
      document.getElementById('view-completed-form').classList.remove('hidden');

      // Scroll to top automatically
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function reloadParentEmptyFormAndSignAnother() {
      document.getElementById('parent-approval-form').reset();
      temporarySignatureBase64 = null;
      document.getElementById('signature-preview-container').classList.add('hidden');
      document.getElementById('signature-placeholder-info').classList.remove('hidden');
      document.getElementById('health-details-container').classList.add('hidden');

      // Toggle Views again
      document.getElementById('view-completed-form').classList.add('hidden');
      document.getElementById('view-parent-fill').classList.remove('hidden');
      
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // SIGNATURE PAD CANVAS UTILITIES (Mouse/Touch)
    function initSignatureCanvasEngine() {
      canvas = document.getElementById('signature-canvas');
      if (!canvas) return;
      ctx = canvas.getContext('2d');

      // Prevent scrolling on mobile when drawing
      canvas.addEventListener('touchstart', e => {
        isDrawing = true;
        const pos = getCanvasXY(e);
        lastX = pos.x;
        lastY = pos.y;
        document.getElementById('canvas-hint').classList.add('hidden');
        e.preventDefault();
      }, { passive: false });

      canvas.addEventListener('touchmove', e => {
        if (!isDrawing) return;
        const pos = getCanvasXY(e);
        drawOnCanvas(pos.x, pos.y);
        e.preventDefault();
      }, { passive: false });

      canvas.addEventListener('touchend', () => isDrawing = false);

      // Mouse listeners
      canvas.addEventListener('mousedown', e => {
        isDrawing = true;
        const pos = getCanvasXY(e);
        lastX = pos.x;
        lastY = pos.y;
        document.getElementById('canvas-hint').classList.add('hidden');
      });

      canvas.addEventListener('mousemove', e => {
        if (!isDrawing) return;
        const pos = getCanvasXY(e);
        drawOnCanvas(pos.x, pos.y);
      });

      canvas.addEventListener('mouseup', () => isDrawing = false);
      canvas.addEventListener('mouseleave', () => isDrawing = false);
    }

    function getCanvasXY(e) {
      const rect = canvas.getBoundingClientRect();
      let clientX, clientY;
      
      if (e.touches && e.touches.length > 0) {
        clientX = e.touches[0].clientX;
        clientY = e.touches[0].clientY;
      } else {
        clientX = e.clientX;
        clientY = e.clientY;
      }

      return {
        x: (clientX - rect.left) * (canvas.width / rect.width),
        y: (clientY - rect.top) * (canvas.height / rect.height)
      };
    }

    function drawOnCanvas(x, y) {
      ctx.beginPath();
      ctx.strokeStyle = '#2e1065'; // Brand dark violet/slate
      ctx.lineWidth = 3.5;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
      ctx.moveTo(lastX, lastY);
      ctx.lineTo(x, y);
      ctx.stroke();
      lastX = x;
      lastY = y;
    }

    function promptSignaturePad() {
      const backdrop = document.getElementById('signature-modal-backdrop');
      if (backdrop) backdrop.classList.remove('hidden');

      setTimeout(() => {
        const container = document.getElementById('canvas-container');
        if (container && canvas) {
          canvas.width = container.clientWidth * 2; // double size for crisp resolution
          canvas.height = container.clientHeight * 2;
          ctx = canvas.getContext('2d');
          ctx.scale(2, 2); 
          clearSignatureCanvas();
        }
      }, 100);
    }

    function closeSignaturePad() {
      document.getElementById('signature-modal-backdrop').classList.add('hidden');
    }

    function clearSignatureCanvas() {
      if (!ctx || !canvas) return;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      document.getElementById('canvas-hint').classList.remove('hidden');
    }

    function saveSignatureFromCanvas() {
      if (!canvas) return;
      
      const isBlank = isCanvasBlankCheck();
      if (isBlank) {
        Swal.fire({ icon: 'warning', title: 'שטח ריק', text: 'אנא ציירו את חתימתכם הבלעדית בתיבה לפני שמירה כאישור.' });
        return;
      }

      temporarySignatureBase64 = canvas.toDataURL('image/png');
      
      document.getElementById('signature-preview-img').src = temporarySignatureBase64;
      document.getElementById('signature-preview-container').classList.remove('hidden');
      document.getElementById('signature-placeholder-info').classList.add('hidden');

      updateParentFormButtonState();
      closeSignaturePad();
    }

    function isCanvasBlankCheck() {
      if (!canvas) return true;
      const buffer = new Uint32Array(ctx.getImageData(0, 0, canvas.width, canvas.height).data.buffer);
      return !buffer.some(color => color !== 0);
    }

    function updateParentFormButtonState() {
      const btn = document.getElementById('parent-submit-btn');
      if (!btn) return;

      const childName = (document.getElementById('parent-child-name')?.value || '').trim();
      const childId = (document.getElementById('parent-child-id')?.value || '').trim();
      const childGrade = (document.getElementById('parent-child-grade')?.value || '');
      
      const parentName = (document.getElementById('parent-parent-name')?.value || '').trim();
      const parentPhone = (document.getElementById('parent-parent-phone')?.value || '').trim();
      const parentId = (document.getElementById('parent-parent-id')?.value || '').trim();

      const isChildIdValid = /^[0-9]{9}$/.test(childId);
      const isParentIdValid = /^[0-9]{9}$/.test(parentId);
      const isPhoneValid = /^05[0-9]{8}$/.test(parentPhone);

      const isChildNameValid = childName.length > 0;
      const isParentNameValid = parentName.length > 0;

      let isGradeValid = true;
      if (parentFormTemplateObj && parentFormTemplateObj.include_grade_question !== false) {
        isGradeValid = childGrade.length > 0;
      }

      const healthRad = document.querySelector('input[name="health-clause"]:checked');
      let isHealthValid = false;
      if (healthRad) {
        if (healthRad.value === 'none') {
          isHealthValid = true;
        } else if (healthRad.value === 'custom') {
          const det = (document.getElementById('health-details-textarea')?.value || '').trim();
          isHealthValid = det.length > 0;
        }
      }

      let isWaterValid = true;
      if (parentFormTemplateObj && parentFormTemplateObj.show_water_clause) {
        const waterRad = document.querySelector('input[name="water-clause"]:checked');
        isWaterValid = !!waterRad;
      }

      const isSignatureValid = !!temporarySignatureBase64;

      const isFormFullyFilled = isChildNameValid && isChildIdValid && isGradeValid &&
                                isParentNameValid && isPhoneValid && isParentIdValid &&
                                isHealthValid && isWaterValid && isSignatureValid;

      if (isFormFullyFilled) {
        btn.disabled = false;
        btn.className = "w-full bg-brand-600 hover:bg-brand-700 text-white font-extrabold py-3 rounded-2xl text-xs transition-all shadow-md shadow-brand-500/10 cursor-pointer flex items-center justify-center gap-2 hover:scale-101";
      } else {
        btn.disabled = true;
        btn.className = "w-full bg-slate-200 text-slate-400 font-extrabold py-3 rounded-2xl text-xs transition-all flex items-center justify-center gap-2 cursor-not-allowed opacity-60";
      }
    }
  </script>
</body>
</html>
