<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>טופס אישור הורים והצהרת בריאות | מחלקת נוער</title>
  
  <!-- CDN Links -->
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Assistant:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    body {
      font-family: 'Assistant', 'Inter', sans-serif;
    }
    
    /* Print specific media rules for elegant PDF rendering */
    @media print {
      body {
        background: white !important;
        color: black !important;
      }
      .no-print {
        display: none !important;
      }
      .print-only {
        display: block !important;
      }
      .print-card {
        border: none !important;
        box-shadow: none !important;
        padding: 0 !important;
        margin: 0 !important;
        width: 100% !important;
      }
    }
  </style>

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              50: '#f5f3ff',
              100: '#ede9fe',
              200: '#ddd6fe',
              600: '#7c3aed',
              700: '#6d28d9',
              850: '#4c1d95',
              900: '#2e1065',
            }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-slate-50 min-h-screen flex flex-col text-slate-800 antialiased pb-12">

  <!-- ==========================================
      HEADER FOR PARENT FORM PORTAL
     ========================================== -->
  <header class="bg-white border-b border-slate-200 sticky top-0 z-30 shadow-xs no-print">
    <div class="mx-auto max-w-3xl px-4 h-16 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <div class="bg-brand-600 text-white w-9 h-9 rounded-xl flex items-center justify-center shadow-md">
          <i class="fa-solid fa-file-signature text-base"></i>
        </div>
        <div>
          <h1 class="text-sm font-extrabold text-slate-900 tracking-tight leading-none">מערכת אישורי הורים</h1>
          <span class="text-[9px] text-brand-600 font-bold block mt-0.5">פורטל הורים מאשרים</span>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-xs text-slate-400 font-medium whitespace-nowrap"><i class="fa-solid fa-shield-halved text-emerald-500 mr-1"></i> מאובטח</span>
      </div>
    </div>
  </header>

  <main class="flex-grow max-w-3xl w-full mx-auto px-4 pt-6 space-y-6">

    <!-- ==========================================
        VIEW 1: LINK MISSING OR INVALID WRAPPER
       ========================================== -->
    <div id="view-invalid-link" class="hidden bg-white border border-slate-200 rounded-3xl p-8 md:p-12 text-center space-y-6 shadow-sm max-w-xl mx-auto my-12 animate-fade-in">
      <div class="mx-auto w-16 h-16 bg-amber-50 rounded-full flex items-center justify-center text-amber-500 ring-8 ring-amber-50/50">
        <i class="fa-solid fa-triangle-exclamation text-2xl"></i>
      </div>
      
      <div class="space-y-2">
        <h2 class="text-xl font-black text-slate-950 tracking-tight">קישור לא תקין או פג תוקף</h2>
        <p class="text-xs md:text-sm text-slate-500 leading-relaxed">
          גורם זה דורש זיהוי ייחודי של פעילות. אנא ודאו שלחצתם על הקישור המלא שנשלח אליכם בהודעת ה-SMS או הווטסאפ של הקבוצה.
        </p>
      </div>

      <div class="pt-6 border-t border-slate-100 max-w-md mx-auto">
        <p class="text-[11px] text-slate-400">
          במידה והתקלה נמשכת, אנא פנו לרכז הנוער או למדריך לקבלת קישור חדש.
        </p>
      </div>
    </div>

    <!-- ==========================================
        VIEW 2: PARENT FORM FILLING INTERFACE (view-parent-fill)
       ========================================== -->
    <div id="view-parent-fill" class="hidden space-y-6 no-print">
      
      <!-- Announcement / Banner info of activity -->
      <div class="bg-white border border-slate-200 rounded-3xl p-6 lg:p-8 space-y-2 relative overflow-hidden shadow-xs">
        <h2 id="parent-preview-title" class="text-xl lg:text-2xl font-black text-slate-900 tracking-tight">טוען פרטי פעילות...</h2>
        <p id="parent-preview-activity-badge" class="text-xs lg:text-sm text-brand-700 font-bold"></p>
      </div>

      <!-- Core Form card declaration -->
      <form id="parent-approval-form" onsubmit="submitParentDeclaration(event)" class="bg-white border border-slate-200 rounded-3xl p-6 lg:p-8 shadow-sm space-y-6">
        
        <!-- Part A: Fixed Health Declarations -->
        <div class="space-y-4">
          <p class="text-xs font-black text-slate-800 leading-relaxed pt-2">
            אני, ההורה/האפוטרופוס של החניך/ה, מצהיר/ה בזאת כי:
          </p>

          <div class="space-y-2.5">
            <!-- Health Option 1 -->
            <label class="flex items-start gap-3 p-3 border border-slate-100 hover:border-slate-300 rounded-xl transition-all cursor-pointer">
              <input 
                type="radio" 
                name="health-clause" 
                value="none" 
                required 
                onchange="toggleHealthClauseDetails(false)"
                class="mt-0.5 h-4 w-4 text-brand-600 border-slate-300 focus:ring-brand-500"
              />
              <span class="text-xs text-slate-650 leading-relaxed font-semibold">
                לא ידוע לי על מגבלה רפואית המונעת מבני/בתי להשתתף באופן מלא בטיול / פעילות זו
              </span>
            </label>

            <!-- Health Option 2 -->
            <label class="flex items-start gap-3 p-3 border border-slate-100 hover:border-slate-300 rounded-xl transition-all cursor-pointer">
              <input 
                type="radio" 
                name="health-clause" 
                value="custom" 
                onchange="toggleHealthClauseDetails(true)"
                class="mt-0.5 h-4 w-4 text-brand-600 border-slate-300 focus:ring-brand-500"
              />
              <div class="space-y-0.5">
                <span class="text-xs text-slate-650 leading-relaxed font-semibold">
                  לבני/בתי יש מגבלה רפואית כרונית / רגישות / אלרגיה מסכנת חיים
                </span>
                <p class="text-[10px] text-slate-400">יש לפרט להלן את המגבלה ולצרף אישור רופא מטפל המאשר את השתתפותו בפעילות זו</p>
              </div>
            </label>

            <!-- Subdetails textarea for health option 2 -->
            <div id="health-details-container" class="hidden pl-2 pr-7 py-1.5 space-y-1.5">
              <label class="block text-[11px] font-bold text-red-600">פירוט המגבלה הרפואית ונחיות טיפול במקרה חירום *</label>
              <textarea 
                id="health-details-textarea"
                rows="3"
                placeholder="נא לפרט כאן אלרגיות, רגישויות למזון או לתרופות, מחלות רקע כרוניות, והוראות למעקב..."
                class="w-full rounded-xl border border-slate-200 px-3 py-2 text-xs text-slate-800 focus:outline-none focus:border-brand-500"
              ></textarea>
            </div>
          </div>
        </div>

        <!-- Part B: Water activity confirmation clause (Only shows if template has it checked) -->
        <div id="parent-water-clause-block" class="hidden space-y-4 pt-2">
          <p class="text-xs font-black text-slate-800 leading-relaxed pt-2">
            על פי נהלי הבטיחות של משרד החינוך, השתתפות בפעילות מים דורשת הצהרה מפורשת של ההורה:
          </p>

          <div class="space-y-2.5">
            <!-- Water Swim Option A -->
            <label class="flex items-start gap-3 p-3 border border-slate-100 hover:border-slate-200 rounded-xl transition cursor-pointer">
              <input 
                type="radio" 
                name="water-clause" 
                value="can_swim" 
                class="mt-0.5 h-4 w-4 text-blue-600 border-slate-300 focus:ring-blue-500"
              />
              <span class="text-xs text-slate-650 font-semibold leading-relaxed">
                אני מאשר/ת כי בני/בתי יודע/ת לשחות ואני מאשר/ת לו/לה להיכנס למים במסגרת הטיול
              </span>
            </label>

            <!-- Water Swim Option B -->
            <label class="flex items-start gap-3 p-3 border border-slate-100 hover:border-slate-200 rounded-xl transition cursor-pointer">
              <input 
                type="radio" 
                name="water-clause" 
                value="cannot_swim" 
                class="mt-0.5 h-4 w-4 text-blue-600 border-slate-300 focus:ring-blue-500"
              />
              <span class="text-xs text-slate-650 font-semibold leading-relaxed">
                בני/בתי אינו/ה יודע/ת לשחות. ידוע לי כי הוא/היא לא יורשה/תורשה להיכנס למים העמוקים מגובה המותניים ויהיו תחת השגחה צמודה.
              </span>
            </label>
          </div>
        </div>

        <!-- Part C: Commitment & Discipline rules clauses -->
        <div class="space-y-3 pt-2">
          <div class="text-xs font-black text-slate-800 leading-relaxed whitespace-pre-line" id="parent-preview-commitment-text">
            <!-- Loaded dynamically -->
          </div>
        </div>

        <!-- Part D: Fill child information -->
        <div class="space-y-4 pt-2">
          <div class="flex items-center gap-2 border-b border-slate-100 pb-2">
            <span class="bg-brand-50 text-brand-700 w-6 h-6 rounded-lg flex items-center justify-center text-xs font-bold">ד</span>
            <h3 class="text-sm font-extrabold text-slate-900">פרטי החניך / החניכה</h3>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
              <label class="block text-xs font-bold text-slate-700 mb-1">שם מלא של החניך/ה *</label>
              <input 
                type="text" 
                id="parent-child-name" 
                required 
                placeholder="לדוגמה: יונתן כהן"
                oninput="this.value = this.value.replace(/[^A-Za-zא-ת\s]/g, '')"
                pattern="[A-Za-zא-ת\s]+"
                title="אנא הזינו אותיות ורווחים בלבד"
                class="w-full rounded-xl border border-slate-200 px-3.5 py-1.5 text-xs text-slate-800 focus:outline-none focus:border-brand-500 font-medium"
              />
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-700 mb-1">תעודת זהות חניך *</label>
              <input 
                type="text" 
                id="parent-child-id" 
                required 
                maxlength="9"
                inputmode="numeric"
                pattern="[0-9]{9}"
                oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                placeholder="000000000"
                class="w-full rounded-xl border border-slate-200 px-3.5 py-1.5 text-xs text-slate-850 focus:outline-none focus:border-brand-500 font-mono text-center tracking-widest text-slate-900"
              />
            </div>
            <div id="parent-child-grade-container">
              <label class="block text-xs font-bold text-slate-700 mb-1">כיתה *</label>
              <select 
                id="parent-child-grade" 
                required
                class="w-full rounded-xl border border-slate-200 px-3.5 py-1.5 text-xs text-slate-800 focus:outline-none focus:border-brand-500 font-semibold"
              >
                <option value="" disabled selected>בחר כיתה...</option>
                <option value="א">כיתה א'</option>
                <option value="ב">כיתה ב'</option>
                <option value="ג">כיתה ג'</option>
                <option value="ד">כיתה ד'</option>
                <option value="ה">כיתה ה'</option>
                <option value="ו">כיתה ו'</option>
                <option value="ז">כיתה ז'</option>
                <option value="ח">כיתה ח'</option>
                <option value="ט">כיתה ט'</option>
                <option value="י">כיתה י'</option>
                <option value="יא">כיתה י"א</option>
                <option value="יב">כיתה י"ב</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Part E: Fill Parent Info -->
        <div class="space-y-4 pt-2">
          <div class="flex items-center gap-2 border-b border-slate-100 pb-2">
            <span class="bg-brand-50 text-brand-700 w-6 h-6 rounded-lg flex items-center justify-center text-xs font-bold">ה</span>
            <h3 class="text-sm font-extrabold text-slate-900">פרטי ההורה / האפוטרופוס המאשר</h3>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
              <label class="block text-xs font-bold text-slate-700 mb-1">שם מלא של ההורה *</label>
              <input 
                type="text" 
                id="parent-parent-name" 
                required 
                placeholder="לדוגמה: שרה כהן"
                oninput="this.value = this.value.replace(/[^A-Za-zא-ת\s]/g, '')"
                pattern="[A-Za-zא-ת\s]+"
                title="אנא הזינו אותיות ורווחים בלבד"
                class="w-full rounded-xl border border-slate-200 px-3.5 py-1.5 text-xs text-slate-800 focus:outline-none focus:border-brand-500 font-medium"
              />
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-700 mb-1">טלפון הורה *</label>
              <input 
                type="text" 
                id="parent-parent-phone" 
                required 
                maxlength="10"
                inputmode="tel"
                pattern="05[0-9]{8}"
                oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                placeholder="05XXXXXXXX"
                class="w-full rounded-xl border border-slate-200 px-3.5 py-1.5 text-xs text-slate-800 focus:outline-none focus:border-brand-500 font-mono text-center tracking-widest text-slate-900"
              />
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-700 mb-1">תעודת זהות הורה *</label>
              <input 
                type="text" 
                id="parent-parent-id" 
                required 
                maxlength="9"
                inputmode="numeric"
                pattern="[0-9]{9}"
                oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                placeholder="000000000"
                class="w-full rounded-xl border border-slate-200 px-3.5 py-1.5 text-xs text-slate-850 focus:outline-none focus:border-brand-500 font-mono text-center tracking-widest text-slate-900"
              />
            </div>
          </div>
        </div>

        <!-- Part F: Live signature pad drawer container -->
        <div class="space-y-4 pt-2">
          <div class="flex items-center gap-2 border-b border-slate-100 pb-2">
            <span class="bg-brand-50 text-brand-700 w-6 h-6 rounded-lg flex items-center justify-center text-xs font-bold">ו</span>
            <h3 class="text-sm font-extrabold text-slate-900">חתימת הורה מאשר דיגיטלית *</h3>
          </div>

          <div class="flex flex-col items-center justify-center p-3 bg-slate-50 border border-slate-200 hover:border-slate-350 rounded-2xl w-full">
            <div id="signature-placeholder-info" class="text-center py-4 space-y-1">
              <i class="fa-solid fa-signature text-3xl text-brand-600 animate-pulse"></i>
              <p class="text-xs font-extrabold text-slate-700">לחצו על הכפתור למטה כדי לפתוח חלון חתימה</p>
              <p class="text-[10px] text-slate-400">יש לצייר את חתימתכם עם האצבע או באמצעות העכבר בחלון שיפתח</p>
            </div>
            
            <div id="signature-preview-container" class="hidden relative max-w-xs w-full bg-white border border-slate-100 shadow-sm rounded-xl overflow-hidden mt-1">
              <img id="signature-preview-img" src="" class="h-28 w-full object-contain bg-slate-100/30" />
              <button 
                type="button" 
                onclick="promptSignaturePad()" 
                class="absolute bottom-1.5 left-1.5 bg-slate-800/80 hover:bg-slate-900 text-white rounded-lg px-2.5 py-1 text-[10px] font-bold transition flex items-center gap-1 shadow-3xs"
              >
                <i class="fa-solid fa-redo"></i>
                <span>חתום שוב</span>
              </button>
            </div>

            <button 
              type="button" 
              id="btn-trigger-signature"
              onclick="promptSignaturePad()" 
              class="mt-3 bg-brand-600 hover:bg-brand-700 text-white font-bold text-xs px-4 py-2 rounded-xl shadow-xs transition inline-flex items-center gap-1.5 cursor-pointer hover:scale-102"
            >
              <i class="fa-solid fa-pen-fancy"></i>
              <span>פתח משטח חתימה</span>
            </button>
          </div>
        </div>

        <!-- Disclaimer & Submission button -->
        <div class="pt-4 border-t border-slate-100 space-y-4">
          <button 
            type="submit" 
            id="parent-submit-btn"
            disabled
            class="w-full bg-slate-200 text-slate-400 font-extrabold py-3 rounded-2xl text-xs transition-all flex items-center justify-center gap-2 cursor-not-allowed opacity-60"
          >
            <i class="fa-solid fa-file-signature"></i>
            <span>שמור והגש אישור חתום לפעילות</span>
          </button>
        </div>

      </form>
    </div>

    <!-- ==========================================
        VIEW 3: COMPLETED FORM DISPLAY (Print Friendly / PDF ready) (view-completed-form)
       ========================================== -->
    <div id="view-completed-form" class="hidden space-y-6">
      
      <!-- High-Polished Success Screen Hero Card (no-print) -->
      <div class="bg-white border border-slate-100 rounded-3xl p-8 md:p-12 text-center space-y-6 shadow-sm no-print">
        <div class="mx-auto w-16 h-16 bg-emerald-50 rounded-full flex items-center justify-center text-emerald-500 ring-8 ring-emerald-50/50">
          <i class="fa-solid fa-check text-2xl"></i>
        </div>
        
        <div class="space-y-2">
          <h2 class="text-xl md:text-2xl font-black text-slate-950 tracking-tight">האישור נשמר בהצלחה במערכת!</h2>
          <p class="text-xs md:text-sm text-slate-500 max-w-md mx-auto leading-relaxed">
            פרטי אישור ההורים והצהרת הבריאות נרשמו בהצלחה במאגר של מחלקת הנוער.
          </p>
        </div>

        <div class="pt-6 border-t border-slate-100 max-w-md mx-auto flex flex-col sm:flex-row items-center justify-center gap-3">
          <button 
            onclick="window.print()" 
            class="w-full sm:w-auto bg-indigo-600 hover:bg-indigo-700 text-white font-extrabold text-xs px-6 py-3 rounded-xl transition flex items-center justify-center gap-2 shadow-xs hover:scale-102 cursor-pointer"
          >
            <i class="fa-solid fa-file-pdf text-sm"></i>
            <span>שמור כ-PDF / הדפס</span>
          </button>
          
          <button 
            onclick="reloadParentEmptyFormAndSignAnother()" 
            class="w-full sm:w-auto bg-slate-50 hover:bg-slate-100 border border-slate-200 text-slate-700 font-extrabold text-xs px-6 py-3 rounded-xl transition flex items-center justify-center gap-2 shadow-3xs cursor-pointer hover:border-slate-300"
          >
            <i class="fa-solid fa-plus text-sm"></i>
            <span>הגש אישור נוסף</span>
          </button>
        </div>
      </div>

      <!-- PDF Page Statement Template (Only visible when printing / compiled) -->
      <div class="hidden print-only bg-white border rounded-3xl p-8 lg:p-12 shadow-sm space-y-8 relative overflow-hidden print-card" style="border-color: #cbd5e1;">
        
        <!-- Header banner structure -->
        <div class="flex justify-between items-start border-b-2 border-slate-200 pb-5">
          <div class="space-y-1">
            <h2 id="pdf-doc-title" class="text-base lg:text-lg font-black text-slate-900 border-none pb-0">הצהרת בריאות ואישור הורים להשתתפות בפעילות</h2>
            <div id="pdf-doc-activity-badge" class="font-bold text-brand-700 text-xs"></div>
            <p class="text-[10px] text-slate-450 font-medium">מספר סימוכין חתימה: <span id="pdf-doc-id-ref" class="font-mono bg-slate-100 px-1 py-0.5 rounded"></span></p>
          </div>
        </div>

        <!-- Section 1 of PDF details of children -->
        <div class="space-y-3">
          <h3 class="text-xs font-bold text-slate-900 border-r-4 border-brand-600 pr-2 pb-0.5">פרטי החניך</h3>
          <div class="grid grid-cols-3 gap-4 text-xs text-slate-800">
            <div class="space-y-1 bg-slate-50/50 p-2.5 rounded-xl border border-slate-100">
              <span class="text-[10px] text-slate-400 font-bold block">שם מלא של החניך/ה:</span>
              <p class="font-bold text-slate-900 text-sm" id="pdf-child-name"></p>
            </div>
            <div class="space-y-1 bg-slate-50/50 p-2.5 rounded-xl border border-slate-100">
              <span class="text-[10px] text-slate-400 font-bold block">תעודת זהות חניך:</span>
              <p class="font-bold font-mono tracking-widest text-slate-900" id="pdf-child-id"></p>
            </div>
            <div id="pdf-child-grade-container" class="space-y-1 bg-slate-50/50 p-2.5 rounded-xl border border-slate-100">
              <span class="text-[10px] text-slate-400 font-bold block">כיתה:</span>
              <p class="font-extrabold text-slate-900" id="pdf-child-grade"></p>
            </div>
          </div>
        </div>

        <!-- Section 1.5 of PDF details of parents -->
        <div class="space-y-3 border-t border-slate-150 pt-5">
